# BPR Perdana eForm — Customer Frontend
# Copy this file: cp .env.example .env
# Then fill in the correct values

# Backend API URL (gunakan IP/domain server staging/production)
PERDANA_EFORM_SERVICE_URL=http://localhost:8081/api/v1/

# VIDA sandbox mode (set false di production)
VITE_VIDA_SANDBOX=true
